# Database connection string for PostgreSQL
DATABASE_URL=postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@localhost:<POSTGRES_PORT>/<POSTGRES_DB>

# Secret key for JWT authentication
JWT_SECRET=<random secret>

# Backend server port
PORT=8000

# Frontend API URL for development
VITE_API_URL=http://localhost:8000

# PostgreSQL environment variables
POSTGRES_USER=appuser  # Username for PostgreSQL
POSTGRES_PASSWORD=securepassword  # Password for PostgreSQL
POSTGRES_DB=appdb  # Database name for PostgreSQL
POSTGRES_PORT=5432  # Port for PostgreSQL

# OpenAI API key for embedding generation
OPENAI_API_KEY=<your_openai_api_key>

# Optional: Other LLM API keys (if applicable)
ANTHROPIC_API_KEY=<your_anthropic_api_key>  # API key for Anthropic models
GOOGLE_GEMINI_API_KEY=<your_google_gemini_api_key>  # API key for Google Gemini models

# Optional: Vector database URL (if using pgvector)
POSTGRES_URL=postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@localhost:<POSTGRES_PORT>/<POSTGRES_DB>